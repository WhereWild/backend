{
  "datasets": [
    {
      "name": "elevation",
      "kind": "raster",
      "fetch": {
        "type": "grid_tiles",
        "grid": "grid.json",
        "raw_subdir": "dem",
        "template": "https://prd-tnm.s3.amazonaws.com/StagedProducts/Elevation/1/TIFF/current/{tile}/USGS_1_{tile}.tif",
        "tile_scheme": "usgs_1deg",
        "workers": 8,
        "skip_if_tif_count_at_least": 1292
      },
      "process": {
        "resampling": "bilinear",
        "overview_levels": [2, 4, 8, 16, 32],
        "dtype": "float32",
        "nodata": -9999,
        "processed_subdir": "dem",
        "single_output_name": "elevation",
        "dem_derivatives": [
          {"type": "slope", "output": "slope.tif"},
          {"type": "aspect", "output": "aspect.tif"}
        ]
      }
    },
    {
      "name": "worldclim_bioclim",
      "kind": "raster",
      "fetch": {
        "type": "direct_zip",
        "url": "https://geodata.ucdavis.edu/climate/worldclim/2_1/base/wc2.1_30s_bio.zip",
        "raw_subdir": "bioclim",
        "extract": true,
        "skip_extract_if_present": "*.tif"
      },
      "process": {
        "resampling": "bilinear",
        "overview_levels": [2, 4, 8, 16, 32],
        "dtype": "float32",
        "nodata": -9999,
        "src_nodata": -3.3999999521443642e38,
        "pixel_size": 1000,
        "processed_subdir": "bioclim",
        "rename_map": {
          "1": "annual_mean_temp",
          "2": "mean_diurnal_range",
          "3": "isothermality",
          "4": "temp_seasonality",
          "5": "max_temp_warmest_month",
          "6": "min_temp_coldest_month",
          "7": "temp_annual_range",
          "8": "mean_temp_wettest_quarter",
          "9": "mean_temp_driest_quarter",
          "10": "mean_temp_warmest_quarter",
          "11": "mean_temp_coldest_quarter",
          "12": "annual_precip",
          "13": "precip_wettest_month",
          "14": "precip_driest_month",
          "15": "precip_seasonality",
          "16": "precip_wettest_quarter",
          "17": "precip_driest_quarter",
          "18": "precip_warmest_quarter",
          "19": "precip_coldest_quarter"
        }
      }
    },
    {
      "name": "nlcd_2024_landcover",
      "kind": "raster",
      "fetch": {
        "type": "direct_zip",
        "env_url_var": "NLCD_2024_URL",
        "urls": [
          "https://www.mrlc.gov/downloads/sciweb1/shared/mrlc/data-bundles/Annual_NLCD_LndCov_2024_CU_C1V1.zip"
        ],
        "zip_name": "Annual_NLCD_LndCov_2024_CU_C1V1.zip",
        "raw_subdir": "landcover",
        "extract": true,
        "skip_extract_if_present": "*.tif"
      },
      "process": {
        "resampling": "mode",
        "overview_levels": [2, 4, 8, 16, 32],
        "dtype": "uint8",
        "nodata": 0,
        "src_nodata": 0,
        "processed_subdir": "landcover_2024",
        "single_output_name": "landcover_2024"
      }
    }
  ]
}
