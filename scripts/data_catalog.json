{
  "datasets": [
    {
      "name": "elevation",
      "kind": "raster",
      "fetch": {
        "type": "grid_tiles",
        "grid": "grid.json",
        "raw_subdir": "dem",
        "template": "https://prd-tnm.s3.amazonaws.com/StagedProducts/Elevation/1/TIFF/current/{tile}/USGS_1_{tile}.tif",
        "tile_scheme": "usgs_1deg",
        "workers": 8
      },
      "process": {
        "resampling": "bilinear",
        "overview_levels": [2, 4, 8, 16, 32],
        "dtype": "float32",
        "nodata": -9999
      }
    },
    {
      "name": "worldclim_bioclim",
      "kind": "raster",
      "fetch": {
        "type": "direct_zip",
        "url": "https://geodata.ucdavis.edu/climate/worldclim/2_1/base/wc2.1_30s_bio.zip",
        "raw_subdir": "bioclim",
        "extract": true
      },
      "process": {
        "resampling": "bilinear",
        "overview_levels": [2, 4, 8, 16, 32],
        "dtype": "float32",
        "nodata": -9999,
        "pixel_size": 1000,
        "rename_map": {
          "1": "bio01_annual_mean_temp",
          "2": "bio02_mean_diurnal_range",
          "3": "bio03_isothermality",
          "4": "bio04_temp_seasonality",
          "5": "bio05_max_temp_warmest_month",
          "6": "bio06_min_temp_coldest_month",
          "7": "bio07_temp_annual_range",
          "8": "bio08_mean_temp_wettest_quarter",
          "9": "bio09_mean_temp_driest_quarter",
          "10": "bio10_mean_temp_warmest_quarter",
          "11": "bio11_mean_temp_coldest_quarter",
          "12": "bio12_annual_precip",
          "13": "bio13_precip_wettest_month",
          "14": "bio14_precip_driest_month",
          "15": "bio15_precip_seasonality",
          "16": "bio16_precip_wettest_quarter",
          "17": "bio17_precip_driest_quarter",
          "18": "bio18_precip_warmest_quarter",
          "19": "bio19_precip_coldest_quarter"
        }
      }
    }
  ]
}
